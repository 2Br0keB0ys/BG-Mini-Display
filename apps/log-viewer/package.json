{
  "name": "bgdisplay-log-viewer",
  "version": "0.1.0",
  "description": "Desktop viewer for BGDisplay Mini diagnostic logs",
  "author": "BGDisplay Mini",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -s first \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src electron --max-warnings 0",
    "format": "prettier --write src electron",
    "format:check": "prettier --check src electron"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "terser": "^5.49.0",
    "vite": "^8.1.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.bgdisplay.logviewer",
    "productName": "BGDisplay Log Viewer",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "win": {
      "target": "nsis"
    }
  }
}
