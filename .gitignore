.DS_Store
Thumbs.db

# Cloudflare/Wrangler local cache
**/.wrangler/

# Firmware build artifacts
firmware/.pio/
.pio/
firmware/src/*.ino.cpp

# Local editor/workspace state
**/.vscode/
**/.idea/

# Local secret material
apps/cloudflare/bgdisplay-device-key.txt
firmware/src/secrets.h
**/secrets.h

# Device provisioning audit logs (contain chip IDs and timing metadata)
firmware/scripts/provision_logs/

# Node modules if installed later
**/node_modules/
**/.eslintcache
**/.cache/
**/coverage/

# Generated UI build output
apps/ui/dist/

# Cloudflare local secrets
apps/cloudflare/.dev.vars
**/.env
**/.env.*
!**/.env.example

# Local Claude/Copilot permission overrides
# (.claude/* instead of .claude/ so settings.json can be un-ignored below;
# git can't re-include a path whose parent directory is itself ignored)
**/.claude/*
!.claude/settings.json
.claude/settings.local.json
.claude/project-context.md
CLAUDE.md
**/.aider*
**/.copilot*
**/.continue/
apps/cloudflare/scripts/.infisical.json
**/.infisical.json

# Local archives and exports
*.7z

# Research data
research/


