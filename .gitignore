apps/cloudflare/.dev.vars
**/.env
**/.env.*
!**/.env.example

# Local Claude/Copilot permission overrides
**/.claude/settings.local.json
apps/cloudflare/scripts/.infisical.json
**/.infisical.json

# Local archives and exports
*.7z

# Research data
research/


