# Required auth
NAS_MCP_API_KEY=replace_with_long_random_api_key
CF_ACCESS_CLIENT_ID=replace_with_cloudflare_service_token_client_id
CF_ACCESS_CLIENT_SECRET=replace_with_cloudflare_service_token_secret

# n8n API
N8N_BASE_URL=https://n8n.example.com
N8N_API_KEY=replace_with_n8n_api_key
N8N_TIMEOUT_MS=20000

# Docker / host controls
DOCKER_CONTAINER_NAME=n8n
DOCKER_COMPOSE_PROJECT_DIR=/volume1/docker/n8n

# Optional local file operations (restricted to this directory)
ALLOWED_FILE_ROOT=/volume1/docker/n8n/workflows

# Server
PORT=8788
